      "claims": {
        "title": "保誠宜家保醫療健康保險附約(AHINTR1)給付項目",
        "source": "保誠宜家保醫療健康保險附約條款",
        "items": [
          {
            "name": "① 住院醫療日額",
            "calc": {
              "type": "unit",
              "perUnit": 1
            },
            "unit": "元/日",
            "note": "依保額日額;住院期間每日給付"
          },
          {
            "name": "② 加護病房日額",
            "calc": {
              "type": "unit",
              "perUnit": 2
            },
            "unit": "元/日",
            "note": "保額×2;住院期間每日給付"
          },
          {
            "name": "③ 燒燙傷病房日額",
            "calc": {
              "type": "unit",
              "perUnit": 2
            },
            "unit": "元/日"
          },
          {
            "name": "④ 出院養護保險金",
            "calc": {
              "type": "unit",
              "perUnit": 1
            },
            "unit": "元/次",
            "note": "保額×1(每次住院出院後給付一次)"
          },
          {
            "name": "⑤ 住院日額加值保險金(65歲前)",
            "calc": {
              "type": "unit",
              "perUnit": 1
            },
            "unit": "元/日",
            "note": "保險年齡未達65歲;住院期間每日加值"
          },
          {
            "name": "⑥ 住院手術醫療保險金",
            "calc": {
              "type": "note",
              "text": "依附表手術倍數(0.2~49 倍)"
            },
            "note": "手術倍數×保額;表外手術依健保支付標準比照;範圍 200元~4.9萬元/次"
          },
          {
            "name": "⑦ 手術療養保險金",
            "calc": {
              "type": "unit",
              "perUnit": 5
            },
            "unit": "元/次",
            "note": "保額×5(每次手術)"
          },
          {
            "name": "⑧ 門診外科手術保險金",
            "calc": {
              "type": "unit",
              "perUnit": 3
            },
            "unit": "元/次",
            "note": "保額×3"
          },
          {
            "name": "⑨ 特定處置保險金",
            "calc": {
              "type": "unit",
              "perUnit": 1
            },
            "unit": "元/次"
          }
        ]
